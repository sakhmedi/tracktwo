# Виртуальное окружение Python (у каждого своё, в репозиторий не кладём)
.venv/
venv/

# Кэш Python
__pycache__/
*.pyc

# Результаты работы программы — генерируются заново при запуске,
# поэтому сами файлы не храним в git, но СОХРАНЯЕМ пустые папки (.gitkeep).
debug/*
!debug/.gitkeep
output/*
!output/.gitkeep
input/*
!input/.gitkeep
